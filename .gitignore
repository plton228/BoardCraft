# Ignore everything in root by default
/*

# Allow specific files in root
!/.gitignore
!/README.md

# Allow specific practical folders
!/Практична 4/
!/Практична 5/
!/Практична 6/

# Inside allowed directories, ignore standard stuff
**/node_modules/
**/dist/
**/.env
**/.env*.local
**/.DS_Store
**/Thumbs.db
**/*.log
**/.prisma/
**/db.sqlite
