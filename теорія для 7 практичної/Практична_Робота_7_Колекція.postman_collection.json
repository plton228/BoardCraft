    {
      "name": "13. Trello - Створення нової дошки (Тести)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response board name matches requested\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql(\"Коледж-Практична-7\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "https://api.trello.com/1/boards?name=Коледж-Практична-7&defaultLists=false&key={{trelloKey}}&token={{trelloToken}}",
          "protocol": "https",
          "host": [
            "api",
            "trello",
            "com"
          ],
          "path": [
            "1",
            "boards"
          ],
          "query": [
            {
              "key": "name",
              "value": "Коледж-Практична-7"
            },
            {
              "key": "defaultLists",
              "value": "false"
            },
            {
              "key": "key",
              "value": "{{trelloKey}}"
            },
            {
              "key": "token",
              "value": "{{trelloToken}}"
            }
          ]
        }
      },
      "response": []
